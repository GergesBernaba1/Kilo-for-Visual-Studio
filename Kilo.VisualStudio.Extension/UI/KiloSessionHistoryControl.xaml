<UserControl x:Class="Kilo.VisualStudio.Extension.UI.KiloSessionHistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="350">
    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="12,8" BorderThickness="0,0,0,1" BorderBrush="#3C3C3C">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Session History" FontSize="14" FontWeight="SemiBold" Foreground="#EEEEEE" VerticalAlignment="Center"/>
                <Button x:Name="RefreshButton" Grid.Column="1" Content="↻" Width="24" Height="24"
                        Background="Transparent" Foreground="#9CA3AF" BorderThickness="0" FontSize="14"
                        Click="RefreshButton_Click" ToolTip="Refresh session list"/>
            </Grid>
        </Border>

        <!-- Session list -->
        <ListBox x:Name="SessionListBox" Grid.Row="1"
                 Background="#1E1E1E" Foreground="#CCCCCC"
                 BorderThickness="0"
                 SelectionChanged="SessionListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#3C3C3C">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="12" FontWeight="SemiBold" Foreground="#EEEEEE" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1" Text="{Binding LastActive}" FontSize="10" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer actions -->
        <Border Grid.Row="2" Background="#252526" Padding="12,8" BorderThickness="0,1,0,0" BorderBrush="#3C3C3C">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SessionCountLabel" Grid.Column="0" Text="0 sessions" Foreground="#9CA3AF" FontSize="11" VerticalAlignment="Center"/>
                <Button x:Name="DeleteButton" Grid.Column="1" Content="Delete" Width="70" Height="26" Margin="0,0,6,0"
                        Background="#7F1D1D" Foreground="#FCA5A5" BorderThickness="0" FontSize="11" Click="DeleteButton_Click" IsEnabled="False"/>
                <Button x:Name="OpenButton" Grid.Column="2" Content="Open" Width="70" Height="26"
                        Background="#0E639C" Foreground="White" BorderThickness="0" FontSize="11" Click="OpenButton_Click" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>